# Caddy — dashboard 외부 진입점 + teslamate UI 게이트.
#
# 구성:
#   :80                            — raw IP HTTP (public IP 직접 접근, 캐시/북마크 호환용).
#   liam-my-dash.duckdns.org       — HTTPS (Let's Encrypt 자동) + Tesla Fleet API public key 서빙.
#   :4000                          — TeslaMate Phoenix UI 게이트 (dashboard 쿠키 인증 통과해야 접속).
#
# Let's Encrypt 계정 이메일: 익명 계정 사용 (개인정보 노출 회피). 필요 시
# 컨테이너 env 로 ACME_EMAIL 주입하고 `email {$ACME_EMAIL}` 한 줄을 글로벌 블록에 추가.

{
	admin off
}

(dashboard_proxy) {
	reverse_proxy dashboard:5000 {
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}
}

# Tesla Fleet API 검증용 HTTPS — Let's Encrypt 자동 발급.
# /.well-known/appspecific/com.tesla.3p.public-key.pem 은 정적 파일로 서빙 (Tesla 검증 경로).
# 나머지 경로는 dashboard 로 프록시.
liam-my-dash.duckdns.org {
	# HSTS — 한 번 HTTPS 로 접속한 브라우저는 1년간 HTTP 시도 자체를 차단.
	header Strict-Transport-Security "max-age=31536000; includeSubDomains"
	# 보안 헤더 — XSS/clickjacking/MIME sniffing 기본 방어.
	header X-Content-Type-Options "nosniff"
	header X-Frame-Options "SAMEORIGIN"
	header Referrer-Policy "strict-origin-when-cross-origin"

	handle /.well-known/appspecific/com.tesla.3p.public-key.pem {
		root * /tesla-keys
		rewrite * /com.tesla.3p.public-key.pem
		file_server
	}
	handle {
		import dashboard_proxy
	}
}

# Raw IP HTTP — 캐시/북마크 호환 (HTTP 만, 인증서 발급 시도 X).
http://43.202.133.239 {
	import dashboard_proxy
}

:4000 {
	forward_auth dashboard:5000 {
		uri /api/auth/verify
	}

	reverse_proxy teslamate:4000 {
		# Phoenix LiveView WebSocket 업그레이드는 Caddy 가 자동으로 처리.
		# Host 는 원본 그대로 (Caddy 기본 동작) — Phoenix LiveView 의 check_origin
		# 이 클라이언트 Origin/Host 를 비교하므로 upstream 으로 덮어쓰면
		# 지오펜스/설정 화면 LiveView 가 원격 명령 폼 제출 시 끊긴다.
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}
}
