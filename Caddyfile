# Caddy — dashboard 외부 진입점 + teslamate UI 게이트.
#
# 구성:
#   :80                              — raw IP (43.202.133.239) HTTP 직접 접근. 캐시/북마크 호환.
#                                      ACME HTTP-01 challenge 도 이 포트로 옴.
#   43-202-133-239.sslip.io (:443)   — HTTPS, Let's Encrypt 자동 cert.
#                                      Spotify OAuth redirect 처럼 HTTPS 요구하는 외부 서비스용.
#                                      sslip.io: <ip>.sslip.io 가 자동으로 해당 IP 로 resolve (가입/DNS 설정 불필요).
#   :4000                            — TeslaMate Phoenix UI 게이트. dashboard 쿠키 인증 통과해야 접속.
#
# auto_https disable_redirects: 명명 사이트(sslip.io) 의 cert 는 발급하되,
#                                raw IP HTTP → HTTPS 자동 redirect 는 막음 (raw IP 엔 cert 없음).

{
	email noreply@43-202-133-239.sslip.io
	admin off
	auto_https disable_redirects
}

(dashboard_proxy) {
	reverse_proxy dashboard:5000 {
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}
}

:80 {
	import dashboard_proxy
}

# sslip.io HTTPS — Spotify 재인증 흐름만 노출 (전체 사이트는 raw IP HTTP 로 유지).
# 외부 노출 면적 최소화: 이 도메인으론 OAuth 콜백 + 재인증 UI + 인증/정적 자산만 통과.
43-202-133-239.sslip.io {
	@allowed {
		path /dev/spotify-relogin /dev/spotify-relogin/*
		path /api/spotify/*
		path /api/auth/*
		path /login /login/*
		path /_next/*
		path /favicon.ico
	}
	handle @allowed {
		import dashboard_proxy
	}
	handle {
		respond "Not Found" 404
	}
}

:4000 {
	forward_auth dashboard:5000 {
		uri /api/auth/verify
	}

	reverse_proxy teslamate:4000 {
		# Phoenix LiveView WebSocket 업그레이드는 Caddy 가 자동으로 처리.
		# Host 는 원본 그대로 (Caddy 기본 동작) — Phoenix LiveView 의 check_origin
		# 이 클라이언트 Origin/Host 를 비교하므로 upstream 으로 덮어쓰면
		# 지오펜스/설정 화면 LiveView 가 원격 명령 폼 제출 시 끊긴다.
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}
}
