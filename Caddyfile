# TeslaMate UI 게이트
# - 외부 :4000 으로 들어오는 요청을 dashboard PIN 쿠키로 검증한 뒤
#   teslamate(Phoenix LiveView, 내부 :4000) 로 프록시.
# - 미인증 시 dashboard /api/auth/verify 가 302 로 /login?next=... 을 돌려준다.
# - dashboard(:80) 는 Caddy 를 거치지 않고 호스트에서 직접 노출되므로
#   여기엔 그 라우팅이 없다.

{
	auto_https off
	admin off
}

:4000 {
	forward_auth dashboard:5000 {
		uri /api/auth/verify
	}

	reverse_proxy teslamate:4000 {
		# Phoenix LiveView WebSocket 업그레이드는 Caddy 가 자동으로 처리.
		# Host 는 원본 그대로 (Caddy 기본 동작) — Phoenix LiveView 의 check_origin
		# 이 클라이언트 Origin/Host 를 비교하므로 upstream 으로 덮어쓰면
		# 지오펜스/설정 화면 LiveView 가 원격 명령 폼 제출 시 끊긴다.
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}
}
